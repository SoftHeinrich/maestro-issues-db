    "task_details": {
        "Component DataNode": {
            "description": "As a developer delving into Hadoop HDFS internals, your task is to understand the design decisions behind the DataNode component. You aim to learn its functionality and grasp its inner workings from components, connectors, and architectural solutions.\n\n",
            "questions": {
                "question1": {
                    "type": "existence",
                    "description": "What are the components and connectors of DataNode, and what is the rationale behind the design decisions on components and connectors?\n\n",
                    "design_decision": {
                        "existence": true
                    }
                },
                "question2": {
                    "type": "property",
                    "description": "What quality attributes are considered in the design of DataNode?\n\n",
                    "design_decision": {
                        "property": true
                    }
                },
                "question3": {
                    "type": "property",
                    "description": "What architectural tactics or patterns used to satisfy the found quality attributes in DataNode?\n\n",
                    "design_decision": {
                        "property": true
                    }
                },
                "question4": {
                    "type": "executive",
                    "description": "What are the technologies applied in the DataNode, and what is the rationale behind selecting these technologies?\n\n",
                    "design_decision": {
                        "executive": true
                    }
                }
            },
